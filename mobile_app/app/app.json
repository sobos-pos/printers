{
  "expo": {
    "name": "Soboss Waiter",
    "slug": "printer",
    "scheme": "soboss",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soboss.waiter",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Soboss Waiter finds the kitchen's leader node on the local Wi-Fi so orders can be placed without internet.",
        "NSBonjourServices": [
          "_soboss._tcp",
          "_soboss._tcp"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.soboss.waiter",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Soboss Waiter uses your location to confirm you are at the restaurant when you clock in."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0b47b57-aaa5-4dfc-b923-c0892e14bd63"
      }
    },
    "owner": "gopal955s-organization"
  }
}
