# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (PostgreSQL)
DB_NAME=soboss_cloud
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# CORS (comma-separated origins; leave empty to deny when DEBUG=False)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security (production)
SECURE_SSL_REDIRECT=False

# Optional: use SQLite for local dev without PostgreSQL
USE_SQLITE=False
