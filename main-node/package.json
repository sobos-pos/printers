{
  "name": "soboss-main-node",
  "version": "1.0.0",
  "description": "Soboss Electron Main Node — local relay, KDS, printer sync",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "test": "vitest run",
    "seed": "node --import tsx scripts/seed-local-config.ts",
    "list-printers": "node --import tsx scripts/list-printers.ts",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.10.0",
    "bonjour-service": "^1.4.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "node-thermal-printer": "^4.6.0",
    "pino": "^10.3.1",
    "uuid": "^11.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.2",
    "electron-vite": "^3.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
